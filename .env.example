# Claude Code API Server - Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind the server to
CCAS_HOST=0.0.0.0

# Port to bind the server to
CCAS_PORT=8000

# Enable debug mode (verbose logging, human-readable format)
CCAS_DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR
CCAS_LOG_LEVEL=INFO

# =============================================================================
# Data Storage
# =============================================================================

# Base directory for all data storage (jobs, uploads, auth)
CCAS_DATA_DIR=/data

# =============================================================================
# Upload Limits
# =============================================================================

# Maximum upload archive size in MB
CCAS_MAX_UPLOAD_SIZE_MB=50

# Maximum total size when archive is extracted in MB
CCAS_MAX_EXTRACTED_SIZE_MB=500

# Maximum number of files allowed in an archive
CCAS_MAX_FILES_PER_ARCHIVE=10000

# =============================================================================
# Job Limits
# =============================================================================

# Maximum number of concurrent jobs
CCAS_MAX_CONCURRENT_JOBS=5

# Maximum number of pending (queued) jobs. New submissions rejected with HTTP 429
CCAS_MAX_PENDING_JOBS=50

# Rate limit in requests per minute. Set to 0 to disable
CCAS_RATE_LIMIT_RPM=100

# Maximum HTTP request body size in MB (non-upload endpoints)
CCAS_MAX_REQUEST_BODY_MB=10

# Default Claude model when client does not specify one
CCAS_DEFAULT_MODEL=claude-sonnet-4-6

# =============================================================================
# Timeouts (in seconds)
# =============================================================================

# Default job timeout (30 minutes)
CCAS_DEFAULT_JOB_TIMEOUT=1800

# Maximum allowed job timeout (2 hours)
CCAS_MAX_JOB_TIMEOUT=7200

# Minimum allowed job timeout (1 minute)
CCAS_MIN_JOB_TIMEOUT=60

# =============================================================================
# Sandbox Settings
# =============================================================================

# Enable process-level bwrap sandbox (recommended: true)
CCAS_ENABLE_BWRAP_SANDBOX=true

# Path to the bwrap binary (resolved via PATH if relative)
# CCAS_BWRAP_PATH=bwrap

# Allow jobs without sandbox when bwrap unavailable (NOT recommended for production)
CCAS_BWRAP_ALLOW_UNSANDBOXED_FALLBACK=false

# Enable per-job network isolation (HTTP proxy + --unshare-net)
CCAS_SANDBOX_NETWORK_ENABLED=true

# Domains always allowed through the network proxy regardless of security profile.
# Comma-separated. Supports wildcard subdomains (*.example.com).
# Default includes Anthropic API and Claude domains.
# CCAS_AUTOALLOWED_DOMAINS=api.anthropic.com,*.anthropic.com,claude.ai,*.claude.ai

# Directory containing seccomp artifacts (apply-seccomp + BPF filter)
# Default: /opt/ccas/seccomp (symlink to @anthropic-ai/sandbox-runtime npm package)
# Falls back to npm root -g discovery if missing
# CCAS_SECCOMP_DIR=/opt/ccas/seccomp

# Upstream HTTP proxy for plain HTTP requests from the per-job network proxy.
# Format: http://[user:pass@]host:port or https://[user:pass@]host:port
# Only affects network-isolated profiles. The unconfined profile is not affected.
# CCAS_UPSTREAM_HTTP_PROXY=

# Upstream HTTPS proxy for HTTPS (CONNECT) requests from the per-job network proxy.
# Format: http://[user:pass@]host:port or https://[user:pass@]host:port
# Only affects network-isolated profiles. The unconfined profile is not affected.
# CCAS_UPSTREAM_HTTPS_PROXY=

# Comma-separated Claude Code setting sources (e.g. user, project, local).
# Empty disables all. Set to 'none' to omit the --setting-sources flag entirely.
# CCAS_SETTING_SOURCES=

# =============================================================================
# MCP Server Settings
# =============================================================================

# Timeout in seconds for each MCP server health check (5–120)
CCAS_MCP_HEALTH_CHECK_TIMEOUT=15

# =============================================================================
# Cleanup Settings (in minutes)
# =============================================================================

# Time-to-live for unused uploads
CCAS_UPLOAD_TTL_MINUTES=30

# Delay before deleting job input files after completion
CCAS_JOB_INPUT_CLEANUP_DELAY_MINUTES=60

# Interval between cleanup task runs
CCAS_CLEANUP_INTERVAL_MINUTES=15

# =============================================================================
# Admin Bootstrap (for production/containerized deployments)
# =============================================================================

# Auto-create admin user on first startup when no admin exists
# Default: false
CCAS_GENERATE_ADMIN_ON_FIRST_STARTUP=false

# RSA public key for encrypting the auto-generated admin token (base64-encoded PEM)
# Required when CCAS_GENERATE_ADMIN_ON_FIRST_STARTUP=true
# Generate with: openssl genrsa -out admin.pem 2048 && openssl rsa -in admin.pem -pubout | base64 -w0
CCAS_ADMIN_TOKEN_ENCRYPTION_KEY=
